{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2024",
    "skipLibCheck": true,
    "strict": true,
    "outDir": "./dist",
    "types": ["node"]
  },
  "include": [
    "src",
    "prisma/**/*.ts", // Inclui arquivos TS dentro da pasta prisma
    "prisma.config.ts", // Inclui o arquivo de config específico
    "index.ts"
  ]
}
